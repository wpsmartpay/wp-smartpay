{
    "name": "wp-smartpay/core",
    "description": "A simple plugin for receiving payment.",
    "require": {
        "php": "^8.1",
        "psr/container": "^1.1.2",
        "symfony/http-foundation": "^5.4.3",
        "symfony/polyfill-mbstring": "1.20.0",
        "symfony/deprecation-contracts": "v2.5.0"
    },
    "autoload": {
        "psr-4": {
            "SmartPay\\": "app/",
            "SmartPay\\Framework\\": "framework/"
        },
        "files": [
            "app/Helpers/smartpay.php",
            "app/Helpers/dashboard.php",
            "framework/helpers.php"
        ],
        "classmap": [
            "database/migrations"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.8",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "*",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2"
    }
}
